# =============================================
# MAA JAGDAMBEY TRADING — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# Server
PORT=5002
NODE_ENV=development

# Database (Neon DB)
DATABASE_URL=postgresql://neondb_owner:npg_YIwU6NqeKX4k@ep-flat-river-a1fdd33c-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# JWT Secrets (use strong random strings — min 32 chars)
JWT_SECRET=your_admin_jwt_secret_min_32_characters_here
CUSTOMER_JWT_SECRET=your_customer_jwt_secret_min_32_characters_here

# Frontend URL (for CORS)
# Development:
CLIENT_URL=http://localhost:5173
# Production (Vercel/Netlify URL):
# CLIENT_URL=https://your-frontend.vercel.app

# ── Meta WhatsApp Business API ──────────────────────────────
# Get from: https://developers.facebook.com → WhatsApp → API Setup
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_WA_ACCESS_TOKEN=your_permanent_access_token_here

# Admin WhatsApp number for low stock alerts (with country code, no +)
# Example: 919876543210 for +91 98765 43210
ADMIN_WHATSAPP_NUMBER=919999999999

# Low stock alert threshold (alert when stock falls below this)
LOW_STOCK_THRESHOLD=3
